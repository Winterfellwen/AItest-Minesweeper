# serverless
.serverless/

# Folders to ignore in Django projects
# If you use collectstatic, you may want to ignore the staticfiles directory.
# staticfiles/
# But note: we are using staticfiles for production, so we don't ignore it.
# However, we do ignore the local static directory if we are using a CDN or something.
# We'll ignore the local static directory in development, but note that we are using
# STATICFILES_DIRS to point to the static directory, so we don't want to ignore that.
# Actually, we want to ignore the collected static files (in STATIC_ROOT) but not the source.
# So we ignore the staticfiles directory (which is STATIC_ROOT) but not the static directory.
staticfiles/

# Webpack
webpack-stats.json

# VS Code
.vscode/

