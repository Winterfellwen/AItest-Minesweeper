.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-top: 20rpx;
}

.tab-bar {
  display: flex;
  padding: 20rpx 40rpx;
  background: #FFFFFF;
  gap: 16rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #78909C;
  background: #F5F5F5;
}

.tab.active {
  background: #E3F2FD;
  color: #1976D2;
  font-weight: 600;
}

.list {
  padding: 20rpx 40rpx;
}

.score-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.rank {
  width: 80rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #78909C;
}

.rank.top-rank {
  color: #FF8F00;
  font-size: 36rpx;
}

.info {
  flex: 1;
}

.nickname {
  font-size: 28rpx;
  color: #37474F;
}

.time-label {
  font-size: 22rpx;
  color: #9E9E9E;
  margin-top: 4rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1976D2;
}

.empty {
  text-align: center;
  color: #9E9E9E;
  padding: 120rpx 0;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  color: #9E9E9E;
  padding: 120rpx 0;
  font-size: 28rpx;
}
