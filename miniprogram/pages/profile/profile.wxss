.container {
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  width: 100%;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #E3F2FD;
  margin-bottom: 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #37474F;
}

.desc {
  font-size: 24rpx;
  color: #9E9E9E;
  margin-top: 16rpx;
}
