.container {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(180deg, #E3F2FD 0%, #F5F5F5 300rpx);
}

.title {
  font-size: 72rpx;
  font-weight: 700;
  color: #1976D2;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #78909C;
  margin-bottom: 80rpx;
}

.difficulty-list {
  width: 100%;
  max-width: 500rpx;
}

.difficulty-btn {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  border: 3rpx solid transparent;
}

.difficulty-btn:active {
  transform: scale(0.98);
}

.diff-label {
  font-size: 36rpx;
  font-weight: 600;
  color: #1976D2;
}

.diff-desc {
  font-size: 24rpx;
  color: #78909C;
  margin-top: 8rpx;
}

.tips {
  margin-top: 100rpx;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  width: 100%;
  max-width: 500rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #37474F;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #78909C;
  line-height: 48rpx;
}
