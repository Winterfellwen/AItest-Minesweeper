<view class="container">
  <view class="title">扫雷</view>
  <view class="subtitle">选择难度开始游戏</view>

  <view class="difficulty-list">
    <view class="difficulty-btn" wx:for="{{difficultyList}}" wx:key="key" bind:tap="onStartGame" data-diff="{{item.key}}">
      <view class="diff-label">{{item.label}}</view>
      <view class="diff-desc">{{item.desc}}</view>
    </view>
  </view>

  <view class="tips">
    <view class="tip-title">游戏提示</view>
    <view class="tip-text">短按翻开格子，长按插旗标记</view>
    <view class="tip-text">所有非雷格子翻开即胜利</view>
  </view>
</view>
