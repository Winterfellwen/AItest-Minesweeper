.game-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

.game-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  background: #FFFFFF;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 22rpx;
  color: #9E9E9E;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1976D2;
  font-variant-numeric: tabular-nums;
}

.restart-btn {
  background: #1976D2;
  color: #FFFFFF;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.restart-btn:active {
  background: #1565C0;
}

.board-wrapper {
  width: 100%;
  padding: 20rpx 20rpx 0;
}

/* Dialog */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100000;
}

.dialog {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx;
  width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 100001;
}

.dialog-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #37474F;
  margin-bottom: 24rpx;
}

.dialog-info {
  font-size: 28rpx;
  color: #78909C;
  line-height: 48rpx;
  margin-bottom: 32rpx;
}

.dialog-actions {
  display: flex;
  flex-direction: column;
  width: 100%;
  gap: 16rpx;
}

.dialog-btn {
  background: #1976D2;
  color: #FFFFFF;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.dialog-btn.secondary {
  background: #F5F5F5;
  color: #37474F;
}
